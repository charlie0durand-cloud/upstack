<div class="row">
  <div class="col-2">
    <%= render "shared/sidebar" %>
  </div>

  <div class="col-10">
    <div class="post-feed">
      <% @posts.each do |post| %>
      <%= link_to post_path(post) do %>
        <div class="post-card">
          <div class="post-card-image">
            <% if post.post_picture.attached? %>
              <%= cl_image_tag post.post_picture.key, crop: :fill %>
            <% else %>
              <img src="https://img.freepik.com/free-photo/nature-landscape-with-hand-holding-frame_23-2149389976.jpg?semt=ais_hybrid&w=740&q=80" alt="">
            <% end %>
          </div>

          <div class="post-card-body">
            <div class="post-card-meta">
              <div class="post-card-author">
                <% if post.user.profile_picture.attached? %>
                  <span><%= image_tag post.user.profile_picture, class: "post-author-avatar" %></span>
                <% else %>
                  <span class="post-author-avatar"><%= post.user.username[0].upcase %></span>
                <% end %>
                <span class="post-author-name"><%= post.user.username %></span>
              </div>
            </div>

            <h2 class="post-title"><%= post.title %></h2>
          </div>
        </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
